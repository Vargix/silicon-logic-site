---
import ThemeToggle from "./ThemeToggle.astro";

const navItems = [
  { href: "/reviews/", label: "Reviews" },
  { href: "/benchmarks/", label: "Benchmarks" },
  { href: "/notes/", label: "Notes" },
  { href: "/methodology/", label: "Methodology" },
  { href: "/concepts/", label: "Concepts" },
  { href: "/archive/", label: "Archive" },
  { href: "/about/", label: "About" },
];

const pathname = Astro.url.pathname;

function isCurrent(href: string) {
  return pathname === href || (href !== "/" && pathname.startsWith(href));
}
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="wordmark" href="/" aria-label="Silicon Logic home">Silicon Logic</a>

    <nav class="site-nav" aria-label="Primary">
      <ul class="site-nav__list">
        {navItems.map((item) => (
          <li>
            <a href={item.href} aria-current={isCurrent(item.href) ? "page" : undefined}>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <ThemeToggle />

    <details class="mobile-nav">
      <summary class="mobile-nav__toggle" aria-label="Open navigation">
        <svg viewBox="0 0 24 24" aria-hidden="true">
          <path d="M4 7h16M4 12h16M4 17h16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
        </svg>
      </summary>
      <ul class="mobile-nav__panel">
        {navItems.map((item) => (
          <li>
            <a href={item.href} aria-current={isCurrent(item.href) ? "page" : undefined}>
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </details>
  </div>
</header>
