---
import BaseLayout from "../layouts/BaseLayout.astro";

const description =
  "Silicon Logic is preparing rigorous local AI inference benchmarks with signed run provenance, pre-registered methodology, and full raw output release.";
---

<BaseLayout
  title="Silicon Logic — Coming Soon"
  description={description}
  canonicalUrl="/"
  pageType="home"
  ogImage="/brand/sl-monogram.png"
>
  <article class="coming-soon" aria-labelledby="coming-soon-title">
    <section class="coming-soon__hero">
      <div class="coming-soon__mark" aria-hidden="true">
        <span class="coming-soon__mark-letter coming-soon__mark-letter--s">S</span>
        <span class="coming-soon__mark-letter coming-soon__mark-letter--l">L</span>
      </div>
      <p class="coming-soon__eyebrow">Coming Soon</p>
      <h1 id="coming-soon-title">Silicon Logic</h1>
      <p class="coming-soon__tagline">
        Rigorous benchmarks for local AI inference, with cryptographic provenance and pre-registered methodology.
      </p>

      <div class="coming-soon__hero-actions">
        <form
          id="email-signup"
          class="coming-soon__signup"
          action="mailto:launch@siliconlogic.dev?subject=Silicon%20Logic%20launch%20list"
          method="post"
          enctype="text/plain"
        >
          <label for="launch-email">Launch list</label>
          <div class="coming-soon__signup-row">
            <input
              id="launch-email"
              name="email"
              type="email"
              inputmode="email"
              autocomplete="email"
              placeholder="you@example.com"
              required
            />
            <button type="submit">Request invite</button>
          </div>
          <a href="mailto:launch@siliconlogic.dev?subject=Silicon%20Logic%20launch%20list&body=Please%20add%20me%20to%20the%20Silicon%20Logic%20launch%20list.">
            Email the launch list directly
          </a>
        </form>

        <a class="coming-soon__preprint-link" href="/methodology-preprint/">
          Methodology v0.9 Pre-Print
        </a>
      </div>
    </section>

    <section class="coming-soon__motion" aria-label="Benchmark pipeline motion graphic">
      <div id="sl-motion-root" class="coming-soon__motion-root"></div>
    </section>

    <div class="coming-soon__body">
      <section class="coming-soon__section" aria-labelledby="first-article-heading">
        <h2 id="first-article-heading">First Report</h2>
        <p>
          Article 1 compares llama.cpp against mlx_lm on Apple Silicon, on throughput, perplexity,
          thermals, and wall and SoC power, using an M5 Max with 36 GB of unified memory.
        </p>
        <p>
          The report will publish with a pre-registration document and signed run hashes, so the benchmark
          record is auditable instead of anecdotal.
        </p>
      </section>

      <section class="coming-soon__section" aria-labelledby="methodology-preview-heading">
        <h2 id="methodology-preview-heading">Methodology Preview</h2>
        <p>
          Silicon Logic treats methodology as part of the artifact: run plans are pre-registered, raw
          outputs are preserved, and claims are tied back to signed measurement records. The methodology
          paper is forthcoming; the <a href="/methodology-preprint/">v0.9 pre-print stub</a> reserves the
          public URL and names the benchmark harness, measurement boundaries, and reporting rules before
          the first review lands.
        </p>
      </section>
    </div>
  </article>

  <footer class="coming-soon__footer" aria-label="Silicon Logic links">
    <span>Silicon Logic&trade;</span>
    <a href="https://x.com/siliconlogic_" aria-label="X: @SiliconLogic, currently redirecting to @siliconlogic_">
      X: @SiliconLogic
    </a>
    <a href="https://github.com/Silicon-Logic">GitHub: Silicon-Logic</a>
  </footer>

  <script is:inline src="https://unpkg.com/react@18.3.1/umd/react.production.min.js" crossorigin="anonymous"></script>
  <script is:inline src="https://unpkg.com/react-dom@18.3.1/umd/react-dom.production.min.js" crossorigin="anonymous"></script>
  <script is:inline src="https://unpkg.com/@babel/standalone@7.29.0/babel.min.js" crossorigin="anonymous"></script>
  <script is:inline type="text/babel" src="/motion/benchmark-pipeline/animations.jsx"></script>
  <script is:inline type="text/babel" src="/motion/benchmark-pipeline/helpers.jsx"></script>
  <script is:inline type="text/babel" src="/motion/benchmark-pipeline/scenes-a.jsx"></script>
  <script is:inline type="text/babel" src="/motion/benchmark-pipeline/scenes-b.jsx"></script>
  <script is:inline type="text/babel" src="/motion/benchmark-pipeline/app.jsx"></script>
</BaseLayout>
