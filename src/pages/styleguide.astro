const diffCode = `def bandwidth_bound(bytes_per_token, tokens_per_second):
    return bytes_per_token * tokens_per_second

peak = bandwidth_bound(5_200_000, 91.2)
peak = bandwidth_bound(5_200_000, 87.3)
