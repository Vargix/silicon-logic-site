---
import IndexLayout from "../layouts/IndexLayout.astro";
---

<IndexLayout
  title="Page not found | Silicon Logic"
  description="This Silicon Logic page does not exist yet."
  canonicalUrl="/404/"
>
  <article class="prose">
    <h1>This page doesn't exist yet.</h1>
    <p>
      Silicon Logic uses durable URLs, so a missing page usually means the article has not been published,
      the route moved before launch, or the address has a small error in it.
    </p>
    <p>
      Try the <a href="/">front page</a>, the <a href="/archive/">archive</a>, or the
      <a href="/methodology/">methodology page</a>.
    </p>
  </article>
</IndexLayout>
