---
import "../styles/tokens.css";
import "../styles/base.css";
import "../styles/components.css";

export interface Props {
  title: string;
  description?: string;
  themeColor?: string;
  pageType?: "home" | "article" | "archive" | "page";
  ogType?: "website" | "article";
  ogImage?: string;
  canonicalUrl?: string;
}

const {
  title,
  description = "Silicon Logic publishes signed benchmarks, technical reviews, and analytical notes on AI hardware and inference runtimes. Every numeric claim is verifiable. Methodology is open.",
  themeColor = "#fbfaf7",
  pageType = "page",
  ogType = pageType === "article" ? "article" : "website",
  ogImage = "/og-image/default.png",
  canonicalUrl,
} = Astro.props;

const site = Astro.site ?? new URL("https://siliconlogic.dev");
const absoluteCanonicalUrl = canonicalUrl
  ? new URL(canonicalUrl, site).toString()
  : new URL(Astro.url.pathname, site).toString();
const absoluteOgImage = new URL(ogImage, site).toString();
const resolvedTitle = title || "Silicon Logic";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{resolvedTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content={themeColor} />
    <link rel="canonical" href={absoluteCanonicalUrl} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={resolvedTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={absoluteOgImage} />
    <meta property="og:url" content={absoluteCanonicalUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={absoluteOgImage} />

    <script is:inline>
      (function() {
        try {
          var stored = localStorage.getItem('silicon-logic-theme');
          var theme = stored ||
            (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.setAttribute('data-theme', theme);
        } catch(e) {
          document.documentElement.setAttribute('data-theme', 'light');
        }
      })();
    </script>

    <link rel="preload" as="font" type="font/woff2"
          href="/fonts/tiempos/tiempos-text-web-regular.woff2" crossorigin />
    <link rel="preload" as="font" type="font/woff2"
          href="/fonts/inter/Inter-Medium.woff2" crossorigin />
  </head>
  <body data-page-type={pageType}>
    <slot name="header" />
    <main><slot /></main>
    <slot name="footer" />
  </body>
</html>
